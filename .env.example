# Only used by the local Vite data proxy. Do not commit `.env.local`.
OCM_API_KEY=replace-with-your-open-charge-map-key
NOBIL_API_KEY=replace-with-your-nobil-key

# Trafikkontorets authoritative MC-, handikapp- och gaturegler.
# Request a key at https://openparking.stockholm.se/ and keep it only in `.env.local`.
STOCKHOLM_OPEN_DATA_API_KEY=replace-with-your-stockholm-open-data-key
